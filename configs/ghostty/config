background = #181a22
background-blur = macos-glass-regular
background-opacity = 0.33
clipboard-write = ask
cursor-color = #dfdfdf
cursor-opacity = 0.33
cursor-text = #2b2b2b
font-family = JetBrainsMono Nerd Font Mono
foreground = #dfdfdf
keybind = global:ctrl+shift+grave_accent=toggle_quick_terminal
# Developer workflow keybindings.
# Ghostty uses native macOS tabs. Under AeroSpace they may be exposed
# as windows by macOS APIs, but tabs remain the preferred Ghostty UX.
keybind = super+n=new_tab
keybind = super+t=new_tab
keybind = super+shift+n=new_window
keybind = super+d=new_split:right
keybind = super+shift+d=new_split:down
keybind = super+shift+arrow_up=jump_to_prompt:-1
keybind = super+shift+arrow_down=jump_to_prompt:1
keybind = super+shift+o=toggle_background_opacity
keybind = super+shift+p=toggle_command_palette
keybind = super+shift+r=reload_config
macos-icon = glass
macos-icon-frame = plastic
macos-option-as-alt = left
macos-titlebar-proxy-icon = hidden
macos-titlebar-style = tabs
macos-window-buttons = hidden
palette = 0=#1C1C1C
palette = 8=#737373
palette = 1=#BD5757
palette = 9=#E37774
palette = 2=#57965C
palette = 10=#73BD79
palette = 3=#D6AE58
palette = 11=#F5D273
palette = 4=#3574F0
palette = 12=#548AF7
palette = 5=#8150BE
palette = 13=#A571E6
palette = 6=#238E82
palette = 14=#42B1A4
palette = 7=#DFDFDF
palette = 15=#FFFFFF
quick-terminal-animation-duration = 0.4
quick-terminal-position = center
quick-terminal-screen = macos-menu-bar
selection-background = #2e436e
selection-foreground = #dfdfdf
shell-integration-features = cursor,sudo,title,no-ssh-env,no-ssh-terminfo,path
title = ~tty
# Ensure Ghostty fully quits on Cmd+Q and exits when the last window closes.
# Without this, Cmd+Q can appear to only close a surface and leave ghost
# instances running in the Dock.
keybind = super+q=quit
quit-after-last-window-closed = true

window-padding-balance = true
window-padding-color = extend
window-subtitle = working-directory
window-theme = ghostty
window-title-font-family = Iosevka Extended
window-vsync = false
